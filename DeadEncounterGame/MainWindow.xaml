<Window x:Class="DeadEncounterGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dungeon Explorer" Height="700" Width="1000"
        Background="#1A1814">

    <Grid>
        <!-- Define 3 columns: left panel | center | right panel -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Player stats -->
        <StackPanel Grid.Column="0" Background="#2E2B25" Margin="0,0,2,0">
            <Label x:Name="lblPlayerName" Content="Player Name"
             Foreground="#C9A84C" FontSize="16" FontWeight="Bold" Margin="10"/>
            <Label Content="Health:" Foreground="White" Margin="10,0,10,0"/>
            <ProgressBar x:Name="pbarPlayerHealth" Height="16"
                   Foreground="#AA3030" Margin="10,0,10,5"/>
            <Label x:Name="lblPlayerHealth" Content="100 / 100"
             Foreground="White" FontSize="12" Margin="10,0"/>
            <Separator Background="#444" Margin="10,8"/>
            <Label Content="INVENTORY" Foreground="#C9A84C"
             FontSize="11" FontWeight="Bold" Margin="10,0"/>
            <ListBox x:Name="lstInventory" Background="#1A1814"
               Foreground="White" Height="150" Margin="10,5"/>
        </StackPanel>

        <!-- CENTER PANEL: Room view -->
        <Grid Grid.Column="1" Margin="2,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <Label x:Name="lblRoomName" Grid.Row="0"
             Content="Entrance Hall" Foreground="#F0D080"
             FontSize="22" FontWeight="Bold" Margin="10,10,10,0"/>

            <Image x:Name="imgRoom" Grid.Row="1" Stretch="UniformToFill"
             Margin="10"/>

            <!-- Direction buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                  HorizontalAlignment="Center" Margin="0,6">
                <Button x:Name="btnNorth" Content="▲ North" Width="90" Margin="4"/>
                <Button x:Name="btnSouth" Content="▼ South" Width="90" Margin="4"/>
                <Button x:Name="btnEast"  Content="▶ East"  Width="90" Margin="4"/>
                <Button x:Name="btnWest"  Content="◀ West"  Width="90" Margin="4"/>
            </StackPanel>

            <!-- Combat log -->
            <TextBox x:Name="txtCombatLog" Grid.Row="3"
               IsReadOnly="True" TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               Background="#0E0C0A" Foreground="#C9E0A0"
               FontFamily="Consolas" FontSize="12" Margin="10,4,10,10"/>
        </Grid>

        <!-- RIGHT PANEL: Enemy + actions -->
        <StackPanel Grid.Column="2" Background="#2E2B25" Margin="2,0,0,0">
            <Label x:Name="lblEnemyStatus" Foreground="White" FontSize="13" Margin="10">
    <TextBlock Text="Room is clear." TextWrapping="Wrap"/>
</Label>
            <ProgressBar x:Name="pbarEnemyHealth" Height="14"
                   Foreground="#8B0000" Margin="10,0"/>
            <Button x:Name="btnAttack" Content="⚔ Attack"
              Visibility="Collapsed" Margin="10,8"/>
            <Button x:Name="btnTalkToNpc" Content="💬 Talk"
              Visibility="Collapsed" Margin="10,4"/>
            <Button x:Name="btnSave" Content="💾 Save Game" Margin="10,4"/>
        </StackPanel>

    </Grid>
</Window>